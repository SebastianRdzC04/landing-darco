---
import ProjectCard from './ProjectCard.astro';

interface Project {
  image: string;
  title: string;
  category: string;
  year?: string;
  href?: string;
}

interface Props {
  title?: string;
  subtitle?: string;
  projects: Project[];
}

const { 
  title = "Proyectos", 
  subtitle = "Una selección de nuestros trabajos más destacados",
  projects 
} = Astro.props;
---

<section id="projects" aria-labelledby="projects-heading" class="relative z-20 bg-white py-16 sm:py-20 md:py-24">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20">
    <!-- Section header -->
    <header class="mb-10 sm:mb-12 md:mb-16 max-w-2xl">
      <span class="text-xs sm:text-sm uppercase tracking-[0.15em] sm:tracking-[0.2em] text-muted font-body">
        Portfolio
      </span>
      <h2 
        id="projects-heading" 
        class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-display text-primary mt-3 sm:mt-4 leading-tight"
      >
        {title}
      </h2>
      <p class="text-sm sm:text-base md:text-lg text-muted mt-4 sm:mt-6 font-body font-light leading-relaxed">
        {subtitle}
      </p>
    </header>
    
    <!-- Projects grid - responsive columns with better spacing -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-3 gap-3 sm:gap-4 md:gap-5 lg:gap-6 auto-rows-max">
      {projects.map((project, index) => (
        <div 
          class="animate-slide-up" 
          style={`animation-delay: ${index * 75}ms`}
        >
          <ProjectCard {...project} />
        </div>
      ))}
    </div>
    
    <!-- View all link -->
    <div class="mt-10 sm:mt-12 md:mt-16 text-center">
      <a 
        href="#contact" 
        class="inline-flex items-center gap-2 sm:gap-3 text-primary hover:text-accent 
               transition-colors duration-300 group py-3 px-4 -mx-4 active:bg-neutral-50 rounded-lg"
      >
        <span class="text-xs sm:text-sm uppercase tracking-[0.1em] sm:tracking-[0.15em] font-body">
          Hablemos de tu proyecto
        </span>
        <svg 
          class="w-4 h-4 sm:w-5 sm:h-5 transform group-hover:translate-x-1 transition-transform" 
          fill="none" 
          stroke="currentColor" 
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</section>
