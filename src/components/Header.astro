---
interface Props {
  siteName?: string;
}

const { siteName = "DARCO" } = Astro.props;

const pathname = Astro.url.pathname;
const isHomePage = pathname === "/" || pathname === "/index.html";

// En homepage: anchor links puros → sin recarga
// En subpáginas: rutas absolutas con hash → navegación real al inicio
const base = isHomePage ? "" : "/";

const navLinks = [
  { href: isHomePage ? "/" : "/", label: "Inicio", isHome: true },
  { href: `${base}#projects`, label: "Proyectos" },
  { href: `${base}#about`,    label: "Nosotros"  },
  { href: `${base}#contact`,  label: "Contacto"  },
];

// Páginas con hero oscuro necesitan texto blanco inicial en el header
const darkHero = !isHomePage;
---

<header
  id="site-header"
  data-dark-hero={darkHero ? "true" : "false"}
  class:list={[
    "fixed inset-x-0 top-0 z-50 transition-all duration-300",
    darkHero && "text-white",
  ]}
>
  <nav
    class="w-full px-5 sm:px-6 md:px-12 lg:px-20 py-4 sm:py-5 flex items-center justify-between"
  >
    <!-- Logo -->
    <a
      href={isHomePage ? "/" : "/"}
      class="font-display text-lg sm:text-xl tracking-wide hover:opacity-70 transition-opacity"
    >
      {siteName}
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-6 lg:gap-10">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm uppercase tracking-[0.12em] lg:tracking-[0.15em] font-body font-light hover:opacity-60 transition-opacity duration-300"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 -mr-2 relative z-50 touch-manipulation"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <div class="w-6 h-6 flex flex-col justify-center items-center gap-1.5">
        <span
          id="menu-line-1"
          class="block w-5 h-0.5 bg-current transition-all duration-300 origin-center"
        ></span>
        <span
          id="menu-line-2"
          class="block w-5 h-0.5 bg-current transition-all duration-300"
        ></span>
        <span
          id="menu-line-3"
          class="block w-5 h-0.5 bg-current transition-all duration-300 origin-center"
        ></span>
      </div>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 bg-black/20 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
    aria-hidden="true"
  ></div>

  <!-- Mobile Menu Panel -->
  <div
    id="mobile-menu"
    class="fixed inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl
           transform translate-x-full transition-transform duration-300 ease-out
           md:hidden flex flex-col text-primary"
  >
    <!-- Menu Header -->
    <div class="flex items-center justify-between px-5 py-4 border-b border-neutral-100">
      <span class="font-display text-lg tracking-wide">{siteName}</span>
      <button
        id="mobile-menu-close"
        class="p-2 -mr-2 touch-manipulation"
        aria-label="Cerrar menú"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Menu Links -->
    <nav class="flex-1 overflow-y-auto py-8">
      <ul class="flex flex-col px-5">
        {
          navLinks.map((link, index) => (
            <li class="border-b border-neutral-100 last:border-b-0">
              <a
                href={link.href}
                class="mobile-menu-link flex items-center justify-between py-5 text-lg font-display tracking-wide
                       hover:text-accent active:text-accent transition-colors touch-manipulation"
                style={`--delay: ${index * 50}ms`}
              >
                <span>{link.label}</span>
                <svg
                  class="w-5 h-5 text-neutral-300"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5l7 7-7 7" />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Menu Footer -->
    <div class="px-5 py-6 border-t border-neutral-100 bg-neutral-50">
      <a
        href={`${base}#contact`}
        class="mobile-menu-link flex items-center justify-center gap-2 w-full py-4 bg-primary text-white
               font-body text-sm uppercase tracking-[0.15em] active:bg-accent transition-colors touch-manipulation"
      >
        <span>Contactar</span>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>

  <style>
    /* Hamburger → X animation */
    .menu-open #menu-line-1 { transform: translateY(4px) rotate(45deg); }
    .menu-open #menu-line-2 { opacity: 0; }
    .menu-open #menu-line-3 { transform: translateY(-4px) rotate(-45deg); }

    /* Slide-in animation for mobile menu links */
    .mobile-menu-link {
      opacity: 0;
      transform: translateX(20px);
      transition:
        opacity 0.3s ease,
        transform 0.3s ease,
        color 0.2s ease;
      transition-delay: var(--delay, 0ms);
    }

    #mobile-menu.menu-visible .mobile-menu-link {
      opacity: 1;
      transform: translateX(0);
    }
  </style>

  <script>
    // ─── Mobile menu ───────────────────────────────────────────────────────────
    const mobileMenuBtn     = document.getElementById("mobile-menu-btn");
    const mobileMenuClose   = document.getElementById("mobile-menu-close");
    const mobileMenu        = document.getElementById("mobile-menu");
    const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");

    let isMenuOpen = false;

    function openMenu() {
      isMenuOpen = true;
      mobileMenu?.classList.remove("translate-x-full");
      mobileMenu?.classList.add("translate-x-0", "menu-visible");
      mobileMenuOverlay?.classList.remove("opacity-0", "pointer-events-none");
      mobileMenuOverlay?.classList.add("opacity-100", "pointer-events-auto");
      mobileMenuBtn?.classList.add("menu-open");
      mobileMenuBtn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    }

    function closeMenu() {
      isMenuOpen = false;
      mobileMenu?.classList.add("translate-x-full");
      mobileMenu?.classList.remove("translate-x-0", "menu-visible");
      mobileMenuOverlay?.classList.add("opacity-0", "pointer-events-none");
      mobileMenuOverlay?.classList.remove("opacity-100", "pointer-events-auto");
      mobileMenuBtn?.classList.remove("menu-open");
      mobileMenuBtn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }

    mobileMenuBtn?.addEventListener("click", () => isMenuOpen ? closeMenu() : openMenu());
    mobileMenuClose?.addEventListener("click", closeMenu);
    mobileMenuOverlay?.addEventListener("click", closeMenu);
    mobileMenu?.querySelectorAll("a").forEach((link) => link.addEventListener("click", closeMenu));

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isMenuOpen) closeMenu();
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768 && isMenuOpen) closeMenu();
    });
  </script>

  <script is:inline>
    function setupScroll() {
      const header = document.getElementById("site-header");
      if (!header) return;

      const darkHero = header.getAttribute("data-dark-hero") === "true";

      // Umbral: en páginas de proyecto esperamos hasta la mitad del hero (50vh)
      // En homepage basta con 50px para dar feedback al usuario
      const threshold = darkHero ? window.innerHeight * 0.5 : 50;

      function handleScroll() {
        const past = window.scrollY > threshold;

        if (past) {
          // Fondo blanco opaco + texto oscuro → legible sobre cualquier sección
          header.classList.add("bg-white", "shadow-sm");
          header.classList.remove("bg-black/20", "backdrop-blur-xl", "text-white");
        } else {
          header.classList.remove("bg-white", "shadow-sm");

          if (darkHero) {
            // Hero oscuro: volvemos a texto blanco al subir de nuevo
            header.classList.add("text-white");
            header.classList.remove("bg-black/20", "backdrop-blur-xl");
          } else {
            // Hero claro (homepage): leve fondo oscuro blur al hacer scroll mínimo
            // → ya limpiado arriba, no añadimos nada extra
          }
        }
      }

      window.addEventListener("scroll", handleScroll, { passive: true });
      handleScroll();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", setupScroll);
    } else {
      setupScroll();
    }

    document.addEventListener("astro:page-load", setupScroll);
  </script>
</header>
