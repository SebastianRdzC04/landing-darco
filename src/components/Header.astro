---
interface Props {
  siteName?: string;
}

const { siteName = "DARCO" } = Astro.props;

const navLinks = [
  { href: "#", label: "Inicio" },
  { href: "#projects", label: "Proyectos" },
  { href: "#about", label: "Nosotros" },
  { href: "#contact", label: "Contacto" },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 bg-black"
>
  <nav
    class="w-full px-5 sm:px-6 md:px-12 lg:px-20 py-4 sm:py-5 flex items-center justify-between"
  >
    <!-- Logo -->
    <a
      href="#"
      class="font-display text-lg sm:text-xl tracking-wide hover:opacity-70 transition-opacity text-white"
    >
      {siteName}
    </a>

    <!-- Desktop Navigation -->
    <ul class="hidden md:flex items-center gap-6 lg:gap-10">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm uppercase tracking-[0.12em] lg:tracking-[0.15em] font-body font-light hover:opacity-60 transition-opacity duration-300 text-white"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 -mr-2 relative z-50 touch-manipulation text-white"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <div class="w-6 h-6 flex flex-col justify-center items-center gap-1.5">
        <span
          id="menu-line-1"
          class="block w-5 h-0.5 bg-white transition-all duration-300 origin-center"
        ></span>
        <span
          id="menu-line-2"
          class="block w-5 h-0.5 bg-white transition-all duration-300"></span>
        <span
          id="menu-line-3"
          class="block w-5 h-0.5 bg-white transition-all duration-300 origin-center"
        ></span>
      </div>
    </button>
  </nav>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu-overlay"
    class="fixed inset-0 bg-black/20 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 md:hidden"
    aria-hidden="true"
  >
  </div>

  <!-- Mobile Menu Panel -->
  <div
    id="mobile-menu"
    class="fixed inset-y-0 right-0 w-full max-w-sm bg-white shadow-2xl
           transform translate-x-full transition-transform duration-300 ease-out
           md:hidden flex flex-col"
  >
    <!-- Menu Header -->
    <div
      class="flex items-center justify-between px-5 py-4 border-b border-neutral-100"
    >
      <span class="font-display text-lg tracking-wide">{siteName}</span>
      <button
        id="mobile-menu-close"
        class="p-2 -mr-2 touch-manipulation"
        aria-label="Cerrar menú"
      >
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.5"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Menu Links -->
    <nav class="flex-1 overflow-y-auto py-8">
      <ul class="flex flex-col px-5">
        {
          navLinks.map((link, index) => (
            <li class="border-b border-neutral-100 last:border-b-0">
              <a
                href={link.href}
                class="mobile-menu-link flex items-center justify-between py-5 text-lg font-display tracking-wide 
                     hover:text-accent active:text-accent transition-colors touch-manipulation"
                style={`--delay: ${index * 50}ms`}
              >
                <span>{link.label}</span>
                <svg
                  class="w-5 h-5 text-neutral-300"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="1.5"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Menu Footer -->
    <div class="px-5 py-6 border-t border-neutral-100 bg-neutral-50">
      <a
        href="#contact"
        class="mobile-menu-link flex items-center justify-center gap-2 w-full py-4 bg-primary text-white
               font-body text-sm uppercase tracking-[0.15em] active:bg-accent transition-colors touch-manipulation"
      >
        <span>Contactar</span>
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>
  </div>

  <style>
    /* Hamburger animation */
    .menu-open #menu-line-1 {
      transform: translateY(4px) rotate(45deg);
    }
    .menu-open #menu-line-2 {
      opacity: 0;
    }
    .menu-open #menu-line-3 {
      transform: translateY(-4px) rotate(-45deg);
    }

    /* Slide-in animation for menu links */
    .mobile-menu-link {
      opacity: 0;
      transform: translateX(20px);
      transition:
        opacity 0.3s ease,
        transform 0.3s ease,
        color 0.2s ease;
      transition-delay: var(--delay, 0ms);
    }

    #mobile-menu.menu-visible .mobile-menu-link {
      opacity: 1;
      transform: translateX(0);
    }
  </style>

  <script>
    const mobileMenuBtn = document.getElementById("mobile-menu-btn");
    const mobileMenuClose = document.getElementById("mobile-menu-close");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");

    let isMenuOpen = false;

    // Open menu
    function openMenu() {
      isMenuOpen = true;
      mobileMenu?.classList.remove("translate-x-full");
      mobileMenu?.classList.add("translate-x-0", "menu-visible");
      mobileMenuOverlay?.classList.remove("opacity-0", "pointer-events-none");
      mobileMenuOverlay?.classList.add("opacity-100", "pointer-events-auto");
      mobileMenuBtn?.classList.add("menu-open");
      mobileMenuBtn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    }

    // Close menu
    function closeMenu() {
      isMenuOpen = false;
      mobileMenu?.classList.add("translate-x-full");
      mobileMenu?.classList.remove("translate-x-0", "menu-visible");
      mobileMenuOverlay?.classList.add("opacity-0", "pointer-events-none");
      mobileMenuOverlay?.classList.remove("opacity-100", "pointer-events-auto");
      mobileMenuBtn?.classList.remove("menu-open");
      mobileMenuBtn?.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }

    // Toggle menu
    mobileMenuBtn?.addEventListener("click", () => {
      if (isMenuOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    // Close button
    mobileMenuClose?.addEventListener("click", closeMenu);

    // Close on overlay click
    mobileMenuOverlay?.addEventListener("click", closeMenu);

    // Close mobile menu on link click
    mobileMenu?.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    // Close on escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isMenuOpen) {
        closeMenu();
      }
    });

    // Handle resize - close menu if switching to desktop
    window.addEventListener("resize", () => {
      if (window.innerWidth >= 768 && isMenuOpen) {
        closeMenu();
      }
    });
  </script>
</header>
