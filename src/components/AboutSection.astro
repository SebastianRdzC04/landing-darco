---
interface Props {
  title: string;
  subtitle: string;
}

const { title, subtitle } = Astro.props;
---

<section id="about" aria-labelledby="about-heading" class="relative z-20 bg-white py-16 sm:py-20 md:py-24">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 sm:gap-12 lg:gap-24 items-start">
      <!-- Left: Philosophy -->
      <div class="lg:sticky lg:top-32">
        <span class="text-xs sm:text-sm uppercase tracking-[0.15em] sm:tracking-[0.2em] text-neutral-400 font-body">
          Filosofía
        </span>
        <h2 
          id="about-heading" 
          class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-display text-primary mt-3 sm:mt-4 leading-[1.1]"
        >
          {title}
        </h2>
        <p class="mt-5 sm:mt-8 text-base sm:text-lg text-neutral-500 font-body font-light leading-relaxed max-w-lg">
          {subtitle}
        </p>
      </div>

      <!-- Right: Mission & Services -->
      <div class="space-y-8 sm:space-y-12">
        <slot />
      </div>
    </div>
  </div>
</section>
