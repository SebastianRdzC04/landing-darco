---
interface Props {
  image: string;
  title: string;
  category: string;
  year?: string;
  href?: string;
}

const { image, title, category, year, href } = Astro.props;

const Tag = href ? 'a' : 'article';
---

<Tag
  href={href}
  class:list={[
    "group relative overflow-hidden touch-manipulation block",
    href && "cursor-pointer"
  ]}
>
  <!-- Image container - vertical aspect ratio -->
  <div class="aspect-[3/4] sm:aspect-[4/5] overflow-hidden bg-neutral-100 w-full">
    <img 
      src={image} 
      alt={title}
      class="w-full h-full object-cover transition-transform duration-700 ease-out 
             group-hover:scale-110 group-active:scale-110"
      style="object-position: center 30%;"
      loading="lazy"
      decoding="async"
    />
  </div>
  
  <!-- Overlay on hover/tap - desktop only hover, always visible info on mobile -->
  <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-black/0 to-transparent 
              sm:bg-black/0 sm:group-hover:bg-black/40 
              transition-all duration-500 flex items-end">
    
    <!-- Desktop hover content -->
    <div class="hidden sm:block p-4 md:p-6 w-full translate-y-4 opacity-0 
                group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
      <span class="text-white/70 text-xs md:text-sm uppercase tracking-widest font-body">
        {category}
      </span>
      <h3 class="text-white text-lg md:text-xl lg:text-2xl font-display mt-1">{title}</h3>
      {year && <span class="text-white/60 text-xs md:text-sm mt-2 block">{year}</span>}
      {href && (
        <span class="inline-flex items-center gap-1.5 text-white/80 text-xs uppercase tracking-wider mt-3 font-body">
          Ver proyecto
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </span>
      )}
    </div>
    
    <!-- Mobile always-visible content -->
    <div class="sm:hidden p-3 w-full">
      <span class="text-white/80 text-[10px] uppercase tracking-wider font-body">
        {category}
      </span>
      <h3 class="text-white text-sm font-display mt-0.5 leading-tight line-clamp-2">{title}</h3>
    </div>
  </div>
</Tag>

<style>
  /* Line clamp for long titles on mobile */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
