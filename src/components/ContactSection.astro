---
interface Props {
  email: string;
  phone: string;
  address: string;
}

const { email, phone, address } = Astro.props;
---

<section id="contact" aria-labelledby="contact-heading" class="relative z-20 bg-neutral-50 py-16 sm:py-20 md:py-24">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20">
    <!-- Section header -->
    <header class="mb-10 sm:mb-12 md:mb-16">
      <span class="text-xs sm:text-sm uppercase tracking-[0.15em] sm:tracking-[0.2em] text-neutral-400 font-body">
        Contacto
      </span>
      <h2 
        id="contact-heading" 
        class="text-3xl sm:text-4xl md:text-5xl font-display text-primary mt-3 sm:mt-4"
      >
        Trabajemos juntos
      </h2>
      <p class="mt-4 sm:mt-6 text-sm sm:text-base md:text-lg text-neutral-500 font-body font-light max-w-xl leading-relaxed">
        ¿Tienes un proyecto en mente? Nos encantaría conocerlo y ayudarte a hacerlo realidad.
      </p>
    </header>
    
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10 sm:gap-12 lg:gap-16">
      <!-- Contact Info -->
      <div class="order-2 lg:order-1">
        <div class="grid grid-cols-1 sm:grid-cols-3 lg:grid-cols-1 gap-6 sm:gap-8">
          <div>
            <p class="text-xs sm:text-sm uppercase tracking-[0.1em] sm:tracking-[0.15em] text-neutral-400 font-body mb-1.5 sm:mb-2">
              Email
            </p>
            <a 
              href={`mailto:${email}`} 
              class="text-sm sm:text-base text-primary hover:opacity-60 active:opacity-60 
                     transition-opacity font-body break-all"
            >
              {email}
            </a>
          </div>
          
          <div>
            <p class="text-xs sm:text-sm uppercase tracking-[0.1em] sm:tracking-[0.15em] text-neutral-400 font-body mb-1.5 sm:mb-2">
              Teléfono
            </p>
            <a 
              href={`tel:${phone.replace(/\s/g, '')}`} 
              class="text-sm sm:text-base text-primary hover:opacity-60 active:opacity-60 
                     transition-opacity font-body"
            >
              {phone}
            </a>
          </div>
          
          <div>
            <p class="text-xs sm:text-sm uppercase tracking-[0.1em] sm:tracking-[0.15em] text-neutral-400 font-body mb-1.5 sm:mb-2">
              Ubicación
            </p>
            <p class="text-sm sm:text-base text-primary font-body whitespace-pre-line">
              {address}
            </p>
          </div>
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-2 order-1 lg:order-2">
        <slot />
      </div>
    </div>
  </div>
</section>

<!-- Footer -->
<footer class="relative z-20 bg-primary text-white py-8 sm:py-10 md:py-12">
  <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20">
    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 sm:gap-6">
      <div class="font-display text-lg sm:text-xl tracking-wide">DARCO</div>
      <p class="text-white/60 text-xs sm:text-sm font-body text-center sm:text-right">
        © {new Date().getFullYear()} Darco Construcciones. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
