---
import Layout from "../layouts/Layout.astro";
import HeroSection from "../components/HeroSection.astro";
import AboutSection from "../components/AboutSection.astro";
import AboutCard from "../components/AboutCard.astro";
import ProjectsSection from "../components/ProjectsSection.astro";
import ContactSection from "../components/ContactSection.astro";
import ContactForm from "../components/ContactForm.astro";
import { getCollection } from "astro:content";
import { getImage } from "astro:assets";

// Carousel images
const carouselSlides = ['/CM1.webp', '/imagen2.jpg', '/imagen4.webp', '/fondo-puesto-comida.png'];

// About section content
const aboutTitle = "La arquitectura como filosofía";
const aboutSubtitle = "Diseñar es pensar en la vida que ocurrirá en un lugar: su luz, su memoria y su relación con el entorno. Buscamos soluciones que sean a la vez funcionales, duraderas y poéticas.";

// Load projects from content collection, sorted by year descending
const projectEntries = await getCollection('projects');
const sortedEntries = projectEntries.sort(
  (a, b) => parseInt(b.data.year) - parseInt(a.data.year)
);

// Build optimized cover image src for each project
const projects = await Promise.all(
  sortedEntries.map(async (entry) => {
    const optimized = await getImage({ src: entry.data.coverImage, width: 600, format: 'webp' });
    return {
      image: optimized.src,
      title: entry.data.title,
      category: entry.data.category,
      year: entry.data.year,
      href: `/proyectos/${entry.data.slug}`,
    };
  })
);

// Contact section content
const contactEmail = "info@darcoconstrucciones.com";
const contactPhone = "+57 (1) 234-5678";
const contactAddress = "Calle Principal 123\nBogotá, Colombia";
---

<Layout title="Darco Construcciones">
  <!-- Hero with Carousel -->
  <HeroSection slides={carouselSlides}>
    Darco Construcciones
  </HeroSection>

  <!-- About Section -->
  <AboutSection 
    title={aboutTitle}
    subtitle={aboutSubtitle}
  >
    <AboutCard>
      <Fragment slot="title">Misión</Fragment>
      <Fragment slot="content">
        Nuestra misión es acompañar a cada proyecto desde la idea hasta la
        entrega, combinando rigor técnico y sensibilidad espacial. Trabajamos
        con clientes para crear edificios y espacios que mejoren la calidad de
        vida y respeten el contexto.
      </Fragment>
    </AboutCard>

    <AboutCard>
      <Fragment slot="title">Qué hacemos</Fragment>
      <Fragment slot="content">
        Ofrecemos servicios de diseño arquitectónico, gestión de proyectos,
        dirección de obra y renovación. Cada encargo se aborda con un proceso
        a medida: estudio del sitio, propuesta conceptual, documentación
        técnica y acompañamiento en obra.
      </Fragment>
    </AboutCard>
  </AboutSection>

  <!-- Projects Section — fed by content collection -->
  <ProjectsSection 
    title="Proyectos"
    subtitle="Una selección de nuestros trabajos más destacados en arquitectura y construcción"
    projects={projects}
  />

  <!-- Contact Section -->
  <ContactSection
    email={contactEmail}
    phone={contactPhone}
    address={contactAddress}
  >
    <ContactForm />
  </ContactSection>
</Layout>
