---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.data.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
---

<Layout
  title={`${data.title} — Darco Construcciones`}
  description={data.excerpt}
>
  <!-- Hero cover image -->
  <div class="relative w-full h-[60vh] sm:h-[70vh] md:h-[80vh] overflow-hidden bg-neutral-900">
    <Image
      src={data.coverImage}
      alt={data.title}
      width={1600}
      height={900}
      format="webp"
      class="w-full h-full object-cover object-center opacity-85"
    />
    <!-- Gradient overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-black/30" />

    <!-- Hero text -->
    <div class="absolute bottom-0 left-0 right-0 pb-10 sm:pb-14 md:pb-16">
      <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20">
        <span class="text-white/60 text-xs sm:text-sm uppercase tracking-[0.2em] font-body">
          {data.category}
        </span>
        <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-display text-white mt-2 sm:mt-3 leading-tight">
          {data.title}
        </h1>
      </div>
    </div>
  </div>

  <!-- Project metadata bar -->
  <div class="bg-primary text-white">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20 py-6 sm:py-8">
      <dl class="flex flex-wrap gap-x-10 gap-y-4 sm:gap-x-16">
        <div>
          <dt class="text-white/50 text-[10px] sm:text-xs uppercase tracking-[0.15em] font-body">Año</dt>
          <dd class="text-white text-sm sm:text-base font-body mt-1">{data.year}</dd>
        </div>
        {data.location && (
          <div>
            <dt class="text-white/50 text-[10px] sm:text-xs uppercase tracking-[0.15em] font-body">Ubicación</dt>
            <dd class="text-white text-sm sm:text-base font-body mt-1">{data.location}</dd>
          </div>
        )}
        {data.client && (
          <div>
            <dt class="text-white/50 text-[10px] sm:text-xs uppercase tracking-[0.15em] font-body">Cliente</dt>
            <dd class="text-white text-sm sm:text-base font-body mt-1">{data.client}</dd>
          </div>
        )}
        <div>
          <dt class="text-white/50 text-[10px] sm:text-xs uppercase tracking-[0.15em] font-body">Categoría</dt>
          <dd class="text-white text-sm sm:text-base font-body mt-1">{data.category}</dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Content area -->
  <article class="bg-white py-14 sm:py-20 md:py-24">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">

        <!-- Excerpt / intro — sticky on desktop -->
        <aside class="lg:col-span-4">
          <div class="lg:sticky lg:top-28">
            <p class="text-base sm:text-lg md:text-xl text-primary font-display leading-relaxed font-light">
              {data.excerpt}
            </p>
          </div>
        </aside>

        <!-- Markdown body -->
        <div class="lg:col-span-8 prose prose-neutral max-w-none
                    prose-headings:font-display prose-headings:font-normal prose-headings:text-primary
                    prose-h2:text-2xl prose-h2:sm:text-3xl prose-h2:mt-10 prose-h2:mb-4
                    prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
                    prose-p:font-body prose-p:text-muted prose-p:leading-relaxed prose-p:text-base prose-p:sm:text-lg
                    prose-li:font-body prose-li:text-muted prose-li:text-base prose-li:sm:text-lg
                    prose-strong:text-primary prose-strong:font-medium
                    prose-a:text-accent prose-a:no-underline hover:prose-a:underline">
          <Content />
        </div>
      </div>
    </div>
  </article>

  <!-- Gallery -->
  {data.gallery && data.gallery.length > 0 && (
    <section
      aria-label="Galería del proyecto"
      class="bg-neutral-50 py-14 sm:py-20 md:py-24"
    >
      <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20">
        <h2 class="text-xs sm:text-sm uppercase tracking-[0.2em] text-muted font-body mb-8 sm:mb-12">
          Galería
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-4 md:gap-5">
          {data.gallery.map((img, i) => (
            <div class:list={["overflow-hidden", i === 0 && data.gallery && data.gallery.length > 2 ? "sm:col-span-2" : ""]}>
              <Image
                src={img}
                alt={`${data.title} — imagen ${i + 1}`}
                width={1200}
                height={800}
                format="webp"
                class="w-full object-cover transition-transform duration-700 hover:scale-105"
                style={i === 0 && data.gallery && data.gallery.length > 2 ? "aspect-ratio: 16/7;" : "aspect-ratio: 4/3;"}
              />
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Footer CTA -->
  <div class="bg-white py-14 sm:py-16 border-t border-neutral-100">
    <div class="max-w-7xl mx-auto px-5 sm:px-6 md:px-12 lg:px-20 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <p class="text-muted text-xs sm:text-sm uppercase tracking-[0.15em] font-body">¿Te interesa este tipo de proyecto?</p>
        <p class="text-primary font-display text-2xl sm:text-3xl mt-1">Hablemos.</p>
      </div>
      <a
        href="/#contact"
        class="inline-flex items-center gap-3 bg-primary text-white px-7 py-4
               text-xs sm:text-sm uppercase tracking-[0.15em] font-body
               hover:bg-accent transition-colors duration-300 group"
      >
        Contactar
        <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 8l4 4m0 0l-4 4m4-4H3" />
        </svg>
      </a>
    </div>
  </div>
</Layout>
